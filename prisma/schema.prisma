generator client {
  provider = "prisma-client-js"
}

// Dev local: SQLite (npm run db:push && npm run db:seed)
// Producao: troque para postgresql e DATABASE_URL no .env
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTION
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum AppointmentType {
  SCHEDULE
  BLOCK
}

enum Recurrence {
  NONE
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  NONE
  PENDING
  PAID
}

enum BillingStatus {
  PENDING
  CHARGED
  RECEIVED
}

enum Gender {
  M
  F
  O
}

enum WaitingListPriority {
  LOW
  NORMAL
  HIGH
}

enum WaitingListStatus {
  WAITING
  CONTACTED
  SCHEDULED
  CANCELLED
  NO_ANSWER
}

enum AgendaNoteType {
  DAY
  PROFESSIONAL
  PATIENT
  APPOINTMENT
  RECEPTION
}

enum AgendaNoteVisibility {
  RECEPTION_ONLY
  PROFESSIONAL
  CLINIC
  ADMIN_ONLY
}

enum PrescriptionStatus {
  DRAFT
  FINALIZED
  CANCELLED
}

enum PrescriptionReceiptType {
  SIMPLE
  SPECIAL
}

enum PrescriptionItemType {
  MEDICATION
  EXAM
  VACCINE
  FREE_TEXT
}

enum PrescriptionShareChannel {
  WHATSAPP
  EMAIL
}

enum PrescriptionShareStatus {
  PENDING
  SENT
  FAILED
}

enum FinancialTransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum FinancialCategoryKind {
  INCOME
  EXPENSE
}

enum FinancialTransactionStatus {
  PENDING
  PAID
  CANCELLED
}

enum InventoryMovementType {
  IN
  OUT
  ADJUST
}

enum TissGuideStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  CANCELLED
}

enum SatisfactionSendStatus {
  PENDING
  SENT
  ANSWERED
  EXPIRED
}

model Clinic {
  id           String        @id @default(cuid())
  name         String
  phone        String?
  email        String?
  active       Boolean       @default(true)
  agendaStartTime     String   @default("08:00")
  agendaEndTime       String   @default("17:00")
  lunchStartTime      String   @default("12:00")
  lunchEndTime        String   @default("13:00")
  slotIntervalMinutes Int      @default(30)
  inviteCode          String?  @unique
  cnes                String?
  addressStreet       String?
  addressCity         String?
  addressState        String?
  addressZip          String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  users            UserClinic[]
  invites          ClinicInvite[]
  patients         Patient[]
  appointments     Appointment[]
  waitingList          WaitingListEntry[]
  agendaNotes          AgendaNote[]
  whatsappConnections  WhatsappConnection[]
  whatsappTemplates    WhatsappMessageTemplate[]
  whatsappSettings     ClinicWhatsappSettings?
  whatsappChats        WhatsappChat[]
  prescriptions        Prescription[]
  prescriptionTemplates PrescriptionTemplate[]
  financialAccounts    FinancialAccount[]
  financialCategories  FinancialCategory[]
  costCenters          CostCenter[]
  paymentMethods       PaymentMethod[]
  financialTransactions FinancialTransaction[]
  financeSettings      ClinicFinanceSettings?
  inventoryProducts    InventoryProduct[]
  inventoryMovements   InventoryMovement[]
  tissGuides           TissGuide[]
  satisfactionSurveys  SatisfactionSurvey[]
}

model User {
  id              String               @id @default(cuid())
  name            String
  email           String               @unique
  googleId        String?              @unique
  password        String
  role            Role                 @default(ADMIN)
  active          Boolean              @default(true)
  gender          Gender?
  phone           String?
  cpf             String?              @unique
  profileImage    String?
  isAccountAdmin  Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  clinics              UserClinic[]
  doctorProfile        Doctor?
  linkedDoctors        ReceptionistDoctor[] @relation("ReceptionistLinks")
  waitingListCreated   WaitingListEntry[]   @relation("WaitingListCreator")
  agendaNotesCreated   AgendaNote[]         @relation("AgendaNoteCreator")
  whatsappConnections  WhatsappConnection[]
  prescriptionsCreated Prescription[]       @relation("PrescriptionProfessional")
  prescriptionTemplates PrescriptionTemplate[]
  invitesSent          ClinicInvite[]         @relation("InvitesSent")
  invitesAccepted      ClinicInvite[]         @relation("InvitesAccepted")
}

/// Conexão WhatsApp (Baileys) — uma sessão por registro, vinculada à clínica e ao usuário que conectou.
model WhatsappConnection {
  id                 String    @id @default(cuid())
  clinicId           String
  userId             String
  name               String
  phoneNumber        String?
  status             String    @default("CREATED")
  connectionType     String?
  qrCode             String?
  pairingCode        String?
  lastError          String?
  lastConnectedAt    DateTime?
  lastDisconnectedAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  clinic             Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  authState          WhatsappAuthState?
  chats              WhatsappChat[]
  outbox             WhatsappOutbox[]

  @@index([clinicId])
  @@index([userId])
}

/// Configuração de WhatsApp por clínica (conexão padrão, lembretes automáticos, assistente IA).
model ClinicWhatsappSettings {
  id                   String   @id @default(cuid())
  clinicId             String   @unique
  defaultConnectionId  String?
  reminderOffsetsJson  String   @default("[24]")
  autoRemindersEnabled Boolean  @default(true)
  aiAssistantEnabled   Boolean  @default(false)
  aiAutoReplyEnabled   Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  clinic               Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

/// Template de mensagem com placeholders {{nome}}, {{data}}, etc.
model WhatsappMessageTemplate {
  id        String   @id @default(cuid())
  clinicId  String
  name      String
  body      String
  category  String   @default("MANUAL")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  outbox    WhatsappOutbox[]

  @@index([clinicId])
}

/// Conversa WhatsApp vinculada a paciente quando possível.
model WhatsappChat {
  id            String             @id @default(cuid())
  connectionId  String
  clinicId      String
  patientId     String?
  remoteJid     String
  phoneDigits   String
  lastMessage         String?
  lastMessageAt       DateTime?
  lastMessageFromMe   Boolean            @default(false)
  contactName         String?
  profilePictureUrl   String?
  profilePictureFetchedAt DateTime?
  unreadCount         Int                @default(0)
  aiPaused            Boolean            @default(false)
  aiContextJson String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  connection    WhatsappConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  clinic        Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient       Patient?           @relation(fields: [patientId], references: [id], onDelete: SetNull)
  messages      WhatsappMessage[]

  @@unique([connectionId, remoteJid])
  @@index([clinicId])
  @@index([patientId])
}

/// Mensagem persistida (enviada ou recebida).
model WhatsappMessage {
  id          String       @id @default(cuid())
  chatId      String
  waMessageId String?
  fromMe      Boolean      @default(false)
  type        String       @default("text")
  content     String
  status      String       @default("SENT")
  sentAt      DateTime     @default(now())
  createdAt   DateTime     @default(now())
  chat        WhatsappChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([waMessageId])
}

/// Fila de envio (manual, lembrete, automático).
model WhatsappOutbox {
  id            String                  @id @default(cuid())
  connectionId  String
  clinicId      String
  to            String
  body          String
  templateId    String?
  appointmentId String?
  offsetHours   Int?
  scheduledAt   DateTime                @default(now())
  status        String                  @default("PENDING")
  attempts      Int                     @default(0)
  errorMessage  String?
  sentAt        DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  connection    WhatsappConnection      @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  template      WhatsappMessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  appointment   Appointment?            @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([status, scheduledAt])
  @@index([clinicId])
  @@index([appointmentId])
}

/// Registro de lembrete já enviado por consulta + offset (horas antes).
model AppointmentReminderLog {
  id            String      @id @default(cuid())
  appointmentId String
  offsetHours   Int
  sentAt        DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, offsetHours])
}

/// Credenciais Baileys (creds + chaves) persistidas no banco, vinculadas à conexão/usuário.
model WhatsappAuthState {
  id           String             @id @default(cuid())
  connectionId String             @unique
  authData     String             @default("{}")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  connection   WhatsappConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model UserClinic {
  id            String   @id @default(cuid())
  userId        String
  clinicId      String
  isClinicAdmin Boolean  @default(false)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic        Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([userId, clinicId])
}

model ClinicInvite {
  id           String       @id @default(cuid())
  clinicId     String
  email        String
  role         Role         @default(DOCTOR)
  token        String       @unique
  status       InviteStatus @default(PENDING)
  invitedById  String
  expiresAt    DateTime
  acceptedAt   DateTime?
  acceptedById String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  clinic       Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedBy   User?        @relation("InvitesAccepted", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([clinicId, status])
  @@index([email])
}

model ReceptionistDoctor {
  id             String   @id @default(cuid())
  receptionistId String
  doctorId       String
  createdAt      DateTime @default(now())
  receptionist   User     @relation("ReceptionistLinks", fields: [receptionistId], references: [id], onDelete: Cascade)
  doctor         Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([receptionistId, doctorId])
}

model Patient {
  id             String          @id @default(cuid())
  clinicId       String?
  name           String
  email          String?
  phone          String
  phoneHome      String?
  whatsapp       String?
  cpf            String          @unique
  rg             String?
  patientCode    String?
  birthDate      DateTime
  gender         Gender
  civilName      String?
  socialGender   String?
  referralSource String?
  address        String?
  bloodType      String?
  allergies      String          @default("")
  medications    String          @default("")
  clinicalHistory String         @default("")
  surgicalHistory String         @default("")
  familyHistory  String          @default("")
  habits         String          @default("")
  insurancePlan  String          @default("Particular")
  insuranceCard  String?
  notes          String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  clinic         Clinic?              @relation(fields: [clinicId], references: [id])
  appointments   Appointment[]
  records        MedicalRecord[]
  waitingList    WaitingListEntry[]
  agendaNotes    AgendaNote[]
  whatsappChats  WhatsappChat[]
  prescriptions  Prescription[]
  financialTransactions FinancialTransaction[]
  tissGuides           TissGuide[]
  satisfactionSurveys  SatisfactionSurvey[]
}

model Doctor {
  id                String               @id @default(cuid())
  userId            String?              @unique
  name              String
  email             String               @unique
  phone             String
  cpf               String?
  crm               String               @unique
  specialty         String
  professionalType  String?
  hasOwnAgenda      Boolean              @default(true)
  available         Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  user              User?                @relation(fields: [userId], references: [id])
  appointments      Appointment[]
  records           MedicalRecord[]
  receptionistLinks ReceptionistDoctor[]
  waitingList       WaitingListEntry[]
  agendaNotes       AgendaNote[]
  financialTransactions FinancialTransaction[]
  tissGuides           TissGuide[]
}

model Procedure {
  id           String                 @id @default(cuid())
  name         String                 @unique
  defaultPrice Decimal                @default(0)
  active       Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  appointments AppointmentProcedure[]
  financialTransactions FinancialTransaction[]
}

model WaitingListEntry {
  id                String              @id @default(cuid())
  clinicId          String
  patientId         String
  doctorId          String?
  desiredSpecialty  String?
  priority          WaitingListPriority @default(NORMAL)
  status            WaitingListStatus   @default(WAITING)
  notes             String?
  createdById       String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  clinic            Clinic              @relation(fields: [clinicId], references: [id])
  patient           Patient             @relation(fields: [patientId], references: [id])
  doctor            Doctor?             @relation(fields: [doctorId], references: [id])
  createdBy         User                @relation("WaitingListCreator", fields: [createdById], references: [id])
  appointment       Appointment?
}

model AgendaNote {
  id          String               @id @default(cuid())
  clinicId    String
  title       String
  description String
  date        DateTime
  doctorId    String?
  patientId   String?
  type        AgendaNoteType       @default(DAY)
  visibility  AgendaNoteVisibility @default(CLINIC)
  createdById String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  clinic      Clinic               @relation(fields: [clinicId], references: [id])
  doctor      Doctor?              @relation(fields: [doctorId], references: [id])
  patient     Patient?             @relation(fields: [patientId], references: [id])
  createdBy   User                 @relation("AgendaNoteCreator", fields: [createdById], references: [id])
}

model Appointment {
  id                  String                 @id @default(cuid())
  clinicId            String?
  waitingListEntryId  String?                @unique
  type                AppointmentType        @default(SCHEDULE)
  patientId           String?
  doctorId            String
  date                DateTime
  startTime           String
  endTime             String                 @default("08:30")
  status              AppointmentStatus      @default(SCHEDULED)
  insurancePlan       String                 @default("Particular")
  recurrence          Recurrence             @default(NONE)
  notes               String?
  generatePaymentLink Boolean                @default(false)
  paymentLinkUrl      String?
  paymentStatus       PaymentStatus          @default(NONE)
  reminderSentAt      DateTime?
  startedAt           DateTime?
  endedAt             DateTime?
  cidCode             String?
  cidDescription      String?
  cidVersion          String?
  mainComplaint       String?
  physicalExam        String?
  currentIllnessHistory String?
  historyAndAntecedents String?
  conduct             String?
  prescriptionSummary String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  clinic              Clinic?                @relation(fields: [clinicId], references: [id])
  patient             Patient?               @relation(fields: [patientId], references: [id])
  doctor              Doctor                 @relation(fields: [doctorId], references: [id])
  waitingListEntry    WaitingListEntry?      @relation(fields: [waitingListEntryId], references: [id])
  procedures          AppointmentProcedure[]
  billing             AppointmentBilling?
  reminderLogs        AppointmentReminderLog[]
  whatsappOutbox      WhatsappOutbox[]
  prescriptions       Prescription[]
  financialTransactions FinancialTransaction[]
  tissGuides           TissGuide[]
  satisfactionSurveys  SatisfactionSurvey[]
}

model AppointmentProcedure {
  id            String      @id @default(cuid())
  appointmentId String
  procedureId   String
  quantity      Int         @default(1)
  unitPrice     Decimal
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  procedure     Procedure   @relation(fields: [procedureId], references: [id])

  @@unique([appointmentId, procedureId])
}

model AppointmentBilling {
  id            String        @id @default(cuid())
  appointmentId String        @unique
  totalAmount   Decimal       @default(0)
  chargedAmount Decimal       @default(0)
  billingStatus BillingStatus @default(PENDING)
  receivedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model MedicalRecord {
  id           String   @id @default(cuid())
  patientId    String
  doctorId     String
  date         DateTime @default(now())
  diagnosis    String
  prescription String
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  patient      Patient  @relation(fields: [patientId], references: [id])
  doctor       Doctor   @relation(fields: [doctorId], references: [id])
}

model Cid10 {
  id            String   @id @default(cuid())
  codigo        String   @unique
  descricao     String
  capitulo      String
  capituloDesc  String
  grupo         String
  grupoDesc     String
  categoria     String
  categoriaDesc String
  tipo          String
  searchText    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([codigo])
  @@index([descricao])
  @@index([capitulo])
  @@index([grupo])
  @@index([tipo])
}

model Cid11 {
  id               String   @id @default(cuid())
  codigo           String   @unique
  descricao        String
  bloco            String
  blocoDesc        String
  capitulo         String
  capituloDesc     String
  tipo             String
  cid10Equivalente String?
  searchText       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([codigo])
  @@index([descricao])
  @@index([capitulo])
  @@index([bloco])
  @@index([tipo])
  @@index([cid10Equivalente])
}

model CidInss {
  id            String   @id @default(cuid())
  codigo        String   @unique
  temCarencia   Boolean  @default(false)
  fonteCarencia String?
  temIrpf       Boolean  @default(false)
  fonteIrpf     String?
  temNtep       Boolean  @default(false)
  fonteNtep     String?
  cnaesJson     Json?
  versao        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([codigo])
}

model AuditLog {
  id           String   @id @default(cuid())
  clinicId     String?
  userId       String?
  module       String
  action       String
  entityType   String?
  entityId     String?
  description  String
  metadataJson String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([clinicId, createdAt])
  @@index([userId, createdAt])
}

/// Cache de bulas completas obtidas de fontes oficiais (Anvisa Bulário / metadados Bulapi).
model BulaCache {
  id            String   @id @default(cuid())
  externalId    String   @unique
  substanceKey  String
  substanceName String?
  source        String
  payloadJson   String
  fetchedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([substanceKey])
  @@index([fetchedAt])
}

model Prescription {
  id               String                  @id @default(cuid())
  clinicId         String
  patientId        String
  professionalId   String
  appointmentId    String?
  status           PrescriptionStatus      @default(DRAFT)
  receiptType      PrescriptionReceiptType @default(SIMPLE)
  prescriptionDate DateTime                @default(now())
  showDate         Boolean                 @default(true)
  notes            String?
  validationCode   String?
  accessCode       String?
  pdfPath          String?
  signedAt         DateTime?
  sentAt           DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  clinic           Clinic                  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient          Patient                 @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional     User                    @relation("PrescriptionProfessional", fields: [professionalId], references: [id])
  appointment      Appointment?            @relation(fields: [appointmentId], references: [id])
  items            PrescriptionItem[]
  shares           PrescriptionShare[]
  signature        PrescriptionSignature?

  @@index([clinicId, patientId, status])
  @@index([validationCode])
}

model PrescriptionItem {
  id             String               @id @default(cuid())
  prescriptionId String
  type           PrescriptionItemType
  name           String
  presentation   String?
  dosage         String?
  frequency      String?
  duration       String?
  quantity       String?
  instructions   String?
  continuousUse  Boolean              @default(false)
  extraJson      String?
  sortOrder      Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  prescription   Prescription         @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId, sortOrder])
}

model PrescriptionTemplate {
  id             String                     @id @default(cuid())
  clinicId       String
  professionalId String
  name           String
  description    String?
  visibility     String                     @default("PRIVATE")
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  clinic         Clinic                     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  professional   User                       @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  items          PrescriptionTemplateItem[]

  @@index([clinicId, professionalId])
}

model PrescriptionTemplateItem {
  id            String               @id @default(cuid())
  templateId    String
  type          PrescriptionItemType
  name          String
  presentation  String?
  dosage        String?
  frequency     String?
  duration      String?
  instructions  String?
  continuousUse Boolean              @default(false)
  sortOrder     Int                  @default(0)
  template      PrescriptionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
}

model PrescriptionShare {
  id             String                   @id @default(cuid())
  prescriptionId String
  channel        PrescriptionShareChannel
  recipient      String
  status         PrescriptionShareStatus  @default(PENDING)
  sentAt         DateTime?
  errorMessage   String?
  createdAt      DateTime                 @default(now())
  prescription   Prescription             @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
}

model FinancialAccount {
  id             String   @id @default(cuid())
  clinicId       String
  name           String
  initialBalance Decimal  @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  clinic         Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  transactions   FinancialTransaction[] @relation("AccountTransactions")
  transfersFrom  FinancialTransaction[] @relation("TransferFromAccount")
  transfersTo    FinancialTransaction[] @relation("TransferToAccount")

  @@index([clinicId, active])
}

model FinancialCategory {
  id        String                @id @default(cuid())
  clinicId  String
  name      String
  kind      FinancialCategoryKind
  active    Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  clinic    Clinic                @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]

  @@index([clinicId, kind, active])
}

model CostCenter {
  id        String   @id @default(cuid())
  clinicId  String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]

  @@index([clinicId, active])
}

model PaymentMethod {
  id        String   @id @default(cuid())
  clinicId  String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]

  @@index([clinicId, active])
}

model FinancialTransaction {
  id              String                     @id @default(cuid())
  clinicId        String
  type            FinancialTransactionType
  status          FinancialTransactionStatus @default(PENDING)
  description     String
  amount          Decimal
  date            DateTime
  dueDate         DateTime?
  paidAt          DateTime?
  accountId       String?
  transferFromId  String?
  transferToId    String?
  categoryId      String?
  costCenterId    String?
  paymentMethodId String?
  patientId       String?
  doctorId        String?
  procedureId     String?
  appointmentId   String?
  insurancePlan   String?
  notes           String?
  createdById     String
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  clinic          Clinic                     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  account         FinancialAccount?          @relation("AccountTransactions", fields: [accountId], references: [id], onDelete: SetNull)
  transferFrom    FinancialAccount?          @relation("TransferFromAccount", fields: [transferFromId], references: [id], onDelete: SetNull)
  transferTo      FinancialAccount?          @relation("TransferToAccount", fields: [transferToId], references: [id], onDelete: SetNull)
  category        FinancialCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  costCenter      CostCenter?                @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  paymentMethod   PaymentMethod?             @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  patient         Patient?                   @relation(fields: [patientId], references: [id], onDelete: SetNull)
  doctor          Doctor?                    @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  procedure       Procedure?                 @relation(fields: [procedureId], references: [id], onDelete: SetNull)
  appointment     Appointment?               @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([clinicId, date])
  @@index([clinicId, type, status])
  @@index([patientId])
  @@index([doctorId])
}

model ClinicFinanceSettings {
  id                      String   @id @default(cuid())
  clinicId                String   @unique
  defaultAccountId        String?
  defaultCostCenterId     String?
  defaultPaymentMethodId  String?
  autoGenerateOnAppointment Boolean @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  clinic                  Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

model InventoryProduct {
  id           String   @id @default(cuid())
  clinicId     String
  name         String
  sku          String?
  unit         String   @default("un")
  minStock     Int      @default(0)
  currentStock Int      @default(0)
  expiryDate   DateTime?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  movements    InventoryMovement[]

  @@index([clinicId, active])
  @@index([clinicId, name])
}

model InventoryMovement {
  id          String                @id @default(cuid())
  clinicId    String
  productId   String
  type        InventoryMovementType
  quantity    Int
  notes       String?
  createdById String
  createdAt   DateTime              @default(now())
  clinic      Clinic                @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  product     InventoryProduct      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([clinicId, createdAt])
  @@index([productId])
}

model TissGuide {
  id            String         @id @default(cuid())
  clinicId      String
  appointmentId String?
  patientId     String?
  doctorId      String?
  insurancePlan String         @default("Particular")
  guideNumber   String?
  status        TissGuideStatus @default(DRAFT)
  procedureCode String?
  procedureName String?
  amount        Decimal?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  clinic        Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patient       Patient?       @relation(fields: [patientId], references: [id], onDelete: SetNull)
  doctor        Doctor?        @relation(fields: [doctorId], references: [id], onDelete: SetNull)

  @@index([clinicId, status])
  @@index([appointmentId])
}

model SatisfactionSurvey {
  id            String                 @id @default(cuid())
  clinicId      String
  appointmentId String?
  patientId     String?
  rating        Int?
  comment       String?
  sendStatus    SatisfactionSendStatus @default(PENDING)
  sentAt        DateTime?
  answeredAt    DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  clinic        Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment   Appointment?           @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patient       Patient?               @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([clinicId, sendStatus])
  @@index([appointmentId])
}

/// Stub para assinatura digital (fase futura).
model PrescriptionSignature {
  id              String       @id @default(cuid())
  prescriptionId  String       @unique
  provider        String?
  certificateType String?
  status          String       @default("PENDING")
  signedPdfUrl    String?
  signatureHash   String?
  signedAt        DateTime?
  errorMessage    String?
  createdAt       DateTime     @default(now())
  prescription    Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}
