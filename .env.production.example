# Produção — use como GitHub Variable DOTENV_FILE (Environment Production)
DATABASE_URL="postgresql://clinmax:SENHA_FORTE@127.0.0.1:5433/clinmax?schema=public"
JWT_SECRET="gere-um-secret-longo-aleatorio"
JWT_EXPIRES="7d"
PORT=3550
NODE_ENV=production
PUBLIC_APP_URL="https://clinmax.com.br"

# Opcional — seed admin inicial
ADMIN_EMAIL="admin@clinmax.com.br"
ADMIN_PASSWORD="senha-forte-min-8-chars"

# Postgres do docker-compose.prod.yml (só se subir o compose na VPS)
POSTGRES_USER=clinmax
POSTGRES_PASSWORD=SENHA_FORTE
POSTGRES_DB=clinmax

OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-oss-120b:free"

# GenInfra bucket "clinica-imagem" — HTTP API (não S3 direto com wk_)
STORAGE_ENDPOINT="https://storage.geninfra.com.br"
STORAGE_BUCKET="mwr-user-files"
STORAGE_AVATAR_PREFIX="users/SEU_WORKSPACE_ID/buckets/clinica-imagem"
STORAGE_REGION="us-east-1"
STORAGE_ACCESS_KEY_ID=""
STORAGE_CONNECTION_TOKEN=""
STORAGE_BUCKETS_API_BASE="https://api.geninfra.com.br/api/workspace/buckets"
STORAGE_LIST_FILES_URL="https://api.geninfra.com.br/api/workspace/buckets/connection/files"
STORAGE_CREATE_UPLOAD_URL_ENDPOINT="https://api.geninfra.com.br/api/workspace/buckets/connection/files/upload-url"
STORAGE_DOWNLOAD_URL_TEMPLATE="https://api.geninfra.com.br/api/workspace/buckets/connection/files/{fileId}/download-url"
